# Canonical site URL (no trailing slash) for SEO, JSON-LD, Open Graph, PDF links
VITE_SITE_URL=https://jntuh-important-questions.vercel.app

# Same URL for Vercel serverless /sitemap.xml (optional if VITE_SITE_URL is set in Vercel env)
# SITE_URL=https://jntuh-important-questions.vercel.app

# Optional: absolute URL to default Open Graph / Twitter image (defaults to /pwa-512.png on your domain)
# VITE_OG_IMAGE_URL=

# Google Search Console HTML tag verification
# VITE_GOOGLE_SITE_VERIFICATION=

# Firebase (https://console.firebase.google.com)
# Use project root .env (not src/) — Vite only loads env from here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional. Same GA4 property as gtag in index.html (G-9396NXS3R9) would double-count page views if both run — leave empty when using HTML gtag only.
VITE_FIREBASE_MEASUREMENT_ID=

# reCAPTCHA v3 (optional — verify tokens in Cloud Functions)
VITE_RECAPTCHA_SITE_KEY=
